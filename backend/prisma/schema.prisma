// Grade 12 Entrance Exam Self-Test System - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STUDENT
  INSTRUCTOR
}

enum Stream {
  NATURAL_SCIENCE
  SOCIAL_SCIENCE
}

enum SubjectType {
  STREAM_SPECIFIC
  SHARED
}

enum Gender {
  MALE
  FEMALE
}

model User {
  id         String      @id @default(cuid())
  username   String      @unique
  password   String
  role       Role        @default(STUDENT)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  student    Student?
  instructor Instructor?
}

model Student {
  id           String        @id @default(cuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  studentId    String        @unique
  gender       Gender
  stream       Stream        @default(NATURAL_SCIENCE)
  examAttempts ExamAttempt[]
  comments     Comment[]
}

model Instructor {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])
  stream    Stream
}

model Subject {
  id           String        @id @default(cuid())
  name         String
  stream       Stream?
  type         SubjectType   @default(STREAM_SPECIFIC)
  questions    Question[]
  instructors  Instructor[]
  examAttempts ExamAttempt[]
}



model Question {
  id            String   @id @default(cuid())
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String // "A" | "B" | "C" | "D"
  year          Int      @default(2025)
  subjectId     String? // Made optional for initial migration
  subject       Subject? @relation(fields: [subjectId], references: [id])
  createdBy     String
  createdAt     DateTime @default(now())
}

model ExamAttempt {
  id             String    @id @default(cuid())
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id])
  subjectId      String?
  subject        Subject?  @relation(fields: [subjectId], references: [id])
  year           Int?
  startTime      DateTime
  endTime        DateTime?
  score          Int       @default(0)
  totalQuestions Int
  answers        Json      // { questionId: selectedOption }
  isCompleted    Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

model ExamConfig {
  id              String   @id @default(cuid())
  naturalPassword String   @default("natural123")
  socialPassword  String   @default("social123")
  durationMins    Int      @default(60)
  isActive        Boolean  @default(true)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  createdBy   String
  createdAt   DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  message   String
  createdAt DateTime @default(now())
}
